import { PrismaClient } from '@prisma/client';
import pkg from 'bcryptjs';
const bcrypt = pkg;

const prisma = new PrismaClient();

async function main() {
  console.log('🌱 开始初始化数据...');

  // 创建管理员
  const adminPassword = await bcrypt.hash('admin123', 10);
  const admin = await prisma.user.upsert({
    where: { username: 'admin' },
    update: {},
    create: {
      username: 'admin',
      password: adminPassword,
      name: '管理员',
      role: 'admin',
      status: 'active'
    }
  });
  console.log('✅ 管理员创建成功:', admin.username);

  // 创建普通用户
  const memberPassword = await bcrypt.hash('123456', 10);
  
  const users = [
    { username: 'gll', name: '谷磊磊', position: '研发工程师' },
    { username: 'lyq', name: '李应钦', position: '硬件工程师' },
    { username: 'zyx', name: '章烨鑫', position: '软件工程师' }
  ];

  for (const userData of users) {
    const user = await prisma.user.upsert({
      where: { username: userData.username },
      update: {},
      create: {
        username: userData.username,
        password: memberPassword,
        name: userData.name,
        position: userData.position,
        role: 'member',
        status: 'active'
      }
    });
    console.log('✅ 用户创建成功:', user.name);
  }

  // 创建项目模版（母版 + 变体）
  const reagentMaster = await prisma.projectTemplate.upsert({
    where: { code: 'TPL-REAGENT-MASTER' },
    update: {},
    create: {
      code: 'TPL-REAGENT-MASTER',
      name: '🔬 试剂/芯片开发 全流程模版（母版）',
      description: '母版，包含完整流程，可作为派生模版的基础',
      category: '试剂/芯片',
      isMaster: true,
      content: JSON.stringify({
        phases: [
          { key: 'phase1', name: '立项', tasks: [{ title: '立项申请' }, { title: '可行性分析' }, { title: '评审' }] },
          { key: 'phase2', name: '方案设计', tasks: [{ title: '引物/探针设计' }, { title: '外购/合作方案' }, { title: '国标对照' }] },
          { key: 'phase3', name: '样本收集', tasks: [{ title: '样本来源确认' }, { title: '接收记录' }] },
          { key: 'phase4', name: '片外核酸提取优化', tasks: [{ title: '提取试剂筛选' }, { title: '程序验证' }] },
          { key: 'phase5', name: '片外扩增试剂/程序优化', tasks: [{ title: '扩增体系优化' }, { title: '参数调试' }] },
          { key: 'phase6', name: '芯片试产验证', tasks: [{ title: '试产' }, { title: '实验验证' }, { title: '性能测试' }] },
          { key: 'phase7', name: '量产加工', tasks: [{ title: '量产准备' }, { title: '生产加工' }] },
          { key: 'phase8', name: '客户验证', tasks: [{ title: '送样' }, { title: '客户反馈' }, { title: '验证报告' }] },
          { key: 'phase9', name: '归档', tasks: [{ title: '文档整理' }, { title: '知识库归档' }, { title: '项目总结' }] }
        ],
        milestones: [{ name: '样品可用' }, { name: '试产通过' }, { name: '验证通过' }],
        defaults: { priority: '中' }
      }),
      createdBy: admin.id
    }
  });
  console.log('✅ 模版创建成功:', reagentMaster.name);

  const reagentStandard = await prisma.projectTemplate.upsert({
    where: { code: 'TPL-REAGENT-STD' },
    update: {},
    create: {
      code: 'TPL-REAGENT-STD',
      name: '标准型（完整流程）',
      description: '试剂/芯片 开发-标准型',
      category: '试剂/芯片',
      parentId: reagentMaster.id,
      content: reagentMaster.content,
      createdBy: admin.id
    }
  });
  console.log('✅ 模版创建成功:', reagentStandard.name);

  const reagentFast = await prisma.projectTemplate.upsert({
    where: { code: 'TPL-REAGENT-FAST' },
    update: {},
    create: {
      code: 'TPL-REAGENT-FAST',
      name: '快速验证型（砍掉部分阶段）',
      description: '适用于快速验证流程',
      category: '试剂/芯片',
      parentId: reagentMaster.id,
      content: JSON.stringify({
        phases: [
          { key: 'dev', name: '研发', tasks: [{ title: '样品制备' }, { title: '快速测试' }] },
          { key: 'validation', name: '验证', tasks: [{ title: '快速验证' }] }
        ],
        milestones: [{ name: '验证通过' }],
        defaults: { priority: '高' }
      }),
      createdBy: admin.id
    }
  });
  console.log('✅ 模版创建成功:', reagentFast.name);

  // 设备母版
  const equipMaster = await prisma.projectTemplate.upsert({
    where: { code: 'TPL-EQUIP-MASTER' },
    update: {},
    create: {
      code: 'TPL-EQUIP-MASTER',
      name: '⚙️ 设备开发 全流程模版（母版）',
      description: '设备开发母版',
      category: '设备',
      isMaster: true,
      content: JSON.stringify({
        phases: [
          { key: 'phase1', name: '项目调研', tasks: [{ title: '市场调研' }, { title: '需求收集' }, { title: '竞品分析' }] },
          { key: 'phase2', name: '立项审批', tasks: [{ title: '立项申请' }, { title: '审批流程' }] },
          { key: 'phase3', name: '方案设计', tasks: [{ title: '设备结构设计' }, { title: '硬件设计' }, { title: '芯片设计' }] },
          { key: 'phase4', name: '设计方案评审', tasks: [{ title: '评审会议' }, { title: '评审意见处理' }] },
          { key: 'phase5', name: '设计迭代再评审', tasks: [{ title: '方案修改' }, { title: '二次评审' }] },
          { key: 'phase6', name: '采购', tasks: [{ title: 'BOM清单' }, { title: '供应商选择' }, { title: '采购跟进' }] },
          { key: 'phase7', name: '样机组装联调', tasks: [{ title: '样机组装' }, { title: '软硬件联调' }, { title: '问题记录' }] },
          { key: 'phase8', name: '结合芯片性能测试', tasks: [{ title: '整机性能测试' }, { title: '指标验证' }] },
          { key: 'phase9', name: '加工生产', tasks: [{ title: '量产准备' }, { title: '生产加工' }] },
          { key: 'phase10', name: '客户验证', tasks: [{ title: '送样' }, { title: '客户反馈' }, { title: '验证报告' }] },
          { key: 'phase11', name: '归档', tasks: [{ title: '文档整理' }, { title: '知识库归档' }] }
        ],
        milestones: [{ name: '样机完成' }, { name: '量产准备' }],
        defaults: { priority: '中' }
      }),
      createdBy: admin.id
    }
  });
  console.log('✅ 模版创建成功:', equipMaster.name);

  const equipPerf = await prisma.projectTemplate.upsert({
    where: { code: 'TPL-EQUIP-PERF' },
    update: {},
    create: {
      code: 'TPL-EQUIP-PERF',
      name: '性能测试型（只做测试阶段）',
      description: '只包含性能测试相关任务',
      category: '设备',
      parentId: equipMaster.id,
      content: JSON.stringify({
        phases: [{ key: 'test', name: '性能测试', tasks: [{ title: '性能测试' }, { title: '数据分析' }] }],
        milestones: [{ name: '测试完成' }],
        defaults: { priority: '高' }
      }),
      createdBy: admin.id
    }
  });
  console.log('✅ 模版创建成功:', equipPerf.name);

  // 创建示例项目（使用管理员作为默认负责人）
  const projects = [
    {
      code: 'PLATFORM-2.0C',
      name: '2.0C平台项目',
      type: 'platform',
      subtype: '2.0C',
      status: '进行中',
      position: '核心产品平台升级项目',
      managerId: admin.id
    },
    {
      code: 'PLATFORM-3.0',
      name: '3.0平台项目',
      type: 'platform',
      subtype: '3.0',
      status: '进行中',
      position: '新一代平台研发',
      managerId: admin.id
    },
    {
      code: 'COOP-BS',
      name: '贝索合作项目',
      type: '定制',
      subtype: '贝索',
      status: '待验证',
      position: '与贝索公司的合作项目',
      managerId: admin.id
    },
    {
      code: 'COOP-HNDX',
      name: '海南大学项目',
      type: '合作',
      subtype: '海南大学',
      status: '待加工',
      position: '海南大学联合研发项目',
      managerId: admin.id
    },
    {
      code: 'COOP-HM',
      name: '黑马合作项目',
      type: '合作',
      subtype: '黑马',
      status: '进行中',
      position: '黑马培训合作项目',
      managerId: admin.id
    },
    {
      code: 'TEST-MDX131',
      name: 'MDX131性能测试',
      type: '测试',
      subtype: 'MDX131',
      status: '进行中',
      position: 'MDX131型号设备性能测试验证',
      managerId: admin.id
    },
    {
      code: 'APP-AQUA',
      name: '水产项目',
      type: '应用',
      subtype: '水产',
      status: '进行中',
      position: '水产养殖应用场景落地',
      managerId: admin.id
    },
    {
      code: 'APP-FOOD',
      name: '食品安全检测项目',
      type: '应用',
      subtype: '食品安全',
      status: '规划中',
      position: '食品安全快速检测应用',
      managerId: admin.id
    }
  ];

  for (const projectData of projects) {
    const project = await prisma.project.upsert({
      where: { code: projectData.code },
      update: {},
      create: projectData
    });
    console.log('✅ 项目创建成功:', project.name);
  }

  console.log('🎉 数据初始化完成！');
}

main()
  .catch((e) => {
    console.error('❌ 初始化失败:', e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
