// Prisma Schema for RD PMS
// Database: SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  password   String
  name       String
  position   String   @default("")
  department String   @default("")
  role       String   @default("member") // admin / manager / member
  status     String   @default("active") // active / disabled
  avatar     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  managedProjects    Project[]         @relation("ProjectManager")
  projectMembers     ProjectMember[]
  assignedTasks      Task[]            @relation("TaskAssignee")
  reports            Report[]
  submittedProgress  MonthlyProgress[] @relation("ProgressSubmitter")
  approvedReports    Report[]          @relation("ReportApprover")
  systemLogs         SystemLog[]
  createdDocs        DocDocument[]     @relation("DocCreator")
  approvedDocs       DocDocument[]     @relation("DocApprover")
  createdDocVersions DocVersion[]      @relation("DocVersionCreator")
  createdTemplates   ProjectTemplate[] @relation("TemplateCreator")

  createdFormulas ReagentFormula[] @relation("FormulaCreator")
  prepRecords     PrepRecord[]     @relation("PrepRecordCreator")
}

model Project {
  id         String    @id @default(uuid())
  code       String    @unique // PRJ-2026-001
  name       String
  type       String // platform / 定制 / 合作 / 测试 / 应用
  subtype    String? // 2.0C / 3.0 / 海南大学 / 黑马 等
  status     String    @default("进行中") // 规划中 / 进行中 / 待加工 / 待验证 / 已完成 / 已归档
  position   String? // 项目定位/描述
  managerId  String
  templateId String? // 套用的模版ID，空白项目为null
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  manager         User              @relation("ProjectManager", fields: [managerId], references: [id])
  template        ProjectTemplate?  @relation("ProjectTemplate", fields: [templateId], references: [id], onDelete: SetNull)
  members         ProjectMember[]
  reports         Report[]
  tasks           Task[]
  milestones      Milestone[]
  monthlyProgress MonthlyProgress[]
  reagentFormulas ReagentFormula[]
}

model ProjectTemplate {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  category    String? // reagent_chip | device
  type        String? // 子类型标签，如"快速验证型"
  parentId    String?
  isMaster    Boolean  @default(false)
  content     String? // JSON 描述模版内容，如 phases/tasks/milestones
  createdBy   String
  status      String   @default("active") // active | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   ProjectTemplate?  @relation("TemplateTree", fields: [parentId], references: [id])
  children ProjectTemplate[] @relation("TemplateTree")
  creator  User              @relation("TemplateCreator", fields: [createdBy], references: [id])
  projects Project[]         @relation("ProjectTemplate")

  @@index([category])
  @@index([parentId])
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("member") // manager / member / viewer
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

// 汇报主表（最新状态）
model Report {
  id          String    @id @default(uuid())
  userId      String
  projectId   String
  reportType  String    @default("日报") // 日报 / 周报 / 月报
  month       String // 2026-03
  content     String // JSON格式汇报内容
  status      String    @default("草稿") // 草稿 / 已提交 / 已通过 / 已驳回
  submittedAt DateTime?
  approvedBy  String?
  approvedAt  DateTime?
  approveNote String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approver User?           @relation("ReportApprover", fields: [approvedBy], references: [id])
  versions ReportVersion[]

  @@unique([userId, projectId, month, reportType])
}

// 汇报历史版本
model ReportVersion {
  id        String   @id @default(uuid())
  reportId  String
  version   Int
  content   String // 该版本的内容
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, version])
}

// 项目月度进展
model MonthlyProgress {
  id            String   @id @default(uuid())
  projectId     String
  month         String // 2026-03
  actualWork    String? // 本月实际工作
  completion    Int      @default(0) // 完成度百分比 0-100
  nextPlan      String? // 下月计划
  risks         String? // 风险问题
  projectStatus String? // 项目综合判断
  submittedBy   String
  submittedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submitter User    @relation("ProgressSubmitter", fields: [submittedBy], references: [id])

  @@unique([projectId, month])
}

model Task {
  id          String    @id @default(uuid())
  projectId   String
  title       String
  description String?
  assigneeId  String?
  status      String    @default("待开始") // 待开始 / 进行中 / 已完成 / 已阻塞
  priority    String    @default("中") // 高 / 中 / 低
  phase       String? // 所属阶段名称（来自模版）
  phaseId     String? // 所属阶段ID（来自模版）
  phaseOrder  Int? // 阶段排序（用于进度条计算）
  dueDate     DateTime?
  completedAt DateTime?
  docRefs     String? // JSON数组，存储文档引用 {id, code, title, docType, version}
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  // 新增：前置任务依赖关系
  prerequisites TaskDependency[] @relation("TaskDependencies")
  dependents    TaskDependency[] @relation("DependentTasks")
}

model TaskDependency {
  id             String   @id @default(cuid())
  taskId         String
  prerequisiteId String
  createdAt      DateTime @default(now())

  task         Task @relation("DependentTasks", fields: [taskId], references: [id], onDelete: Cascade)
  prerequisite Task @relation("TaskDependencies", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([taskId, prerequisiteId])
}

model Milestone {
  id          String    @id @default(uuid())
  projectId   String
  name        String
  date        DateTime
  status      String    @default("待完成") // 待完成 / 已完成 / 已延期
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SystemLog {
  id        String   @id @default(uuid())
  action    String // login / logout / report_submit / report_approve 等
  userId    String
  targetId  String? // 关联的记录ID
  detail    String? // 详细描述
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 知识库文档分类
model DocCategory {
  id          String   @id @default(uuid())
  name        String // 分类名称，如：SOP标准操作规程 / 模板文件 / 技术文档
  description String? // 分类描述
  icon        String? // 图标
  sortOrder   Int      @default(0) // 排序
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents DocDocument[]
}

// 知识库文档
model DocDocument {
  id          String    @id @default(uuid())
  categoryId  String
  code        String    @unique // 文档编号，如 SOP-RG-LAMP-001
  title       String // 文档标题
  description String? // 文档描述
  docType     String    @default("sop") // sop / template / guide / reference
  content     String? // 文档内容（富文本或Markdown）
  fileUrl     String? // 附件文件URL
  fileName    String? // 附件文件名
  version     String    @default("V1.0") // 当前版本
  status      String    @default("active") // active / archived / deprecated
  tags        String? // 标签，逗号分隔
  createdBy   String
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  category DocCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  creator  User         @relation("DocCreator", fields: [createdBy], references: [id])
  approver User?        @relation("DocApprover", fields: [approvedBy], references: [id])
  versions DocVersion[]

  @@index([categoryId])
  @@index([docType])
  @@index([status])
}

// 文档版本历史
model DocVersion {
  id         String   @id @default(uuid())
  documentId String
  version    String // 版本号，如 V1.0, V1.1, V2.0
  content    String // 该版本的完整内容
  changelog  String? // 变更说明
  createdBy  String
  createdAt  DateTime @default(now())

  document DocDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  creator  User        @relation("DocVersionCreator", fields: [createdBy], references: [id])

  @@unique([documentId, version])
}

// 试剂与配方：新增模型
model Reagent {
  id               String   @id @default(uuid())
  name             String   @unique // 简称，如 "GITC"
  fullName         String?
  casNumber        String?
  category         String   @default("其他")
  molecularWeight  Float?
  purity           Float?   @default(100)
  density          Float?
  defaultUnit      String   @default("M")
  hazardLevel      String?
  supplier         String?
  storageCondition String?
  notes            String?
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  components FormulaComponent[]

  @@index([category])
}

model ReagentFormula {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String?
  type      String
  pH        Float?
  status    String   @default("草稿")
  projectId String?
  procedure String?
  notes     String?
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator     User               @relation("FormulaCreator", fields: [createdBy], references: [id])
  project     Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  components  FormulaComponent[]
  prepRecords PrepRecord[]

  @@index([type])
  @@index([status])
}

model FormulaComponent {
  id            String  @id @default(uuid())
  formulaId     String
  reagentId     String
  concentration Float
  unit          String  @default("M")
  notes         String?
  sortOrder     Int     @default(0)

  formula ReagentFormula @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  reagent Reagent        @relation(fields: [reagentId], references: [id])

  @@unique([formulaId, reagentId])
  @@index([formulaId])
}

model PrepRecord {
  id           String   @id @default(uuid())
  formulaId    String
  targetVolume Float
  calcResult   String
  prepDate     String
  operator     String?
  batchNo      String?
  notes        String?
  createdBy    String
  createdAt    DateTime @default(now())

  formula ReagentFormula @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  creator User           @relation("PrepRecordCreator", fields: [createdBy], references: [id])

  @@index([formulaId])
}

// 阶段流转关系（用于表示从一个阶段到多个并行后续阶段）
model PhaseTransition {
  id          String   @id @default(cuid())
  fromPhaseId String
  toPhaseId   String
  createdAt   DateTime @default(now())

  @@unique([fromPhaseId, toPhaseId])
}
